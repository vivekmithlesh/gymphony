# Copy to .env (or set in Vercel project env) and fill in real values.

# Fallback origin for QR deep-links (/join/:id, /checkin/:id) used on localhost/dev
# and during SSR. In the live browser the app uses the current domain automatically
# (see src/lib/app-url.ts), so links follow a domain rename. Set = production domain.
VITE_APP_URL=https://your-production-domain.example

# Auth & Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Dummy values for build/validation to pass
MINIO_ACCESS_KEY="dummy_key"
MINIO_SECRET_KEY="dummy_secret"
MINIO_BUCKET="dummy_bucket"
MSG91_API_KEY="your-key"
MSG91_TEMPLATE_ID="your-template"
